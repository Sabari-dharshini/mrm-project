# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/

# Environment files - NEVER commit these
.env
.env.local
.env.production
.env.development
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime
pids/
*.pid
*.seed
*.pid.lock

# Uploads (user data - never commit)
mrmpg-backend/uploads/*
!mrmpg-backend/uploads/.gitkeep

# Prisma
mrmpg-backend/prisma/migrations/*
!mrmpg-backend/prisma/migrations/.gitkeep


# OS
.DS_Store
.DS_Store?
._*
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Terraform state (sensitive - never commit)
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/*.tfvars
terraform/.terraform.lock.hcl

# Docker
.dockerignore
