# ─────────────────────────────────────────────────────────────
#  MRM PG - Environment Variables Template
#  Copy this to .env on your EC2 server and fill in values.
#  NEVER commit the actual .env file to GitHub.
# ─────────────────────────────────────────────────────────────

# EC2 Public IP (get this from AWS console after terraform apply)
EC2_PUBLIC_IP=YOUR_EC2_PUBLIC_IP_HERE

# Database - AWS RDS PostgreSQL
# Format: postgresql://USER:PASSWORD@RDS_ENDPOINT:5432/DATABASE_NAME
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@YOUR_RDS_ENDPOINT:5432/mrmpg

# JWT
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_STRING
JWT_EXPIRES_IN=450d
BCRYPT_SALT_ROUNDS=12

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM=your-email@gmail.com

# Company Info
COMPANY_NAME=MRM PG
COMPANY_WEBSITE=http://YOUR_EC2_PUBLIC_IP_HERE:5173
